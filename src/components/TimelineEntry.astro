---
import { getCollection } from 'astro:content';
import { slugify } from '../lib/slugify';
import type { TimelineUpdate } from '../lib/timeline';

interface Props {
  entry: TimelineUpdate;
}

const { entry } = Astro.props;

const projects = await getCollection('projects');
const project = entry.project ? projects.find((p) => p.id === entry.project) : undefined;

const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

// Format from the string parts to avoid any timezone shift from Date parsing.
function formatDate(iso: string): string {
  const [year, month, day] = iso.split('-').map(Number);
  return `${day} ${MONTHS[month - 1]} ${year}`;
}

const pill = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold border transition-colors';
---

<li class="relative pl-8 md:pl-10">
  {/* Node on the rail */}
  <span
    class="absolute -left-[9px] top-6 w-4 h-4 rounded-full bg-irish-green ring-4 ring-irish-cream shadow-sm"
    aria-hidden="true"
  ></span>

  {/* Update card */}
  <article class="bg-white rounded-xl shadow-sm border border-irish-stone p-6 hover:shadow-md hover:border-irish-green/30 transition-all duration-300">
    <div class="flex items-center justify-between gap-3 flex-wrap mb-3">
      <time datetime={entry.date} class="text-sm font-semibold text-irish-green">
        {formatDate(entry.date)}
      </time>
      <div class="flex items-center gap-2 flex-wrap">
        {project ? (
          <a
            href={`/project/${project.id}`}
            class={`${pill} bg-irish-green/10 text-irish-green border-irish-green/20 hover:bg-irish-green hover:text-white`}
          >
            {project.data.title}
          </a>
        ) : entry.project ? (
          <span class={`${pill} bg-irish-green/10 text-irish-green border-irish-green/20`}>{entry.project}</span>
        ) : null}
        {entry.category && (
          <a
            href={`/category/${slugify(entry.category)}`}
            class={`${pill} bg-irish-charcoal/5 text-irish-charcoal border-irish-stone hover:bg-irish-charcoal hover:text-white`}
          >
            {entry.category}
          </a>
        )}
      </div>
    </div>

    <p class="text-irish-charcoal leading-relaxed mb-4">
      {entry.impact}
    </p>

    <div class="flex items-center justify-between gap-3 flex-wrap pt-4 border-t border-irish-stone">
      <span class="text-sm text-gray-500">
        by
        <a
          href={`/creator/${slugify(entry.creator)}`}
          class="font-medium text-irish-charcoal hover:text-irish-green transition-colors"
        >
          {entry.creator}
        </a>
      </span>
      <a
        href={entry.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center text-sm font-semibold text-irish-green hover:text-irish-green-dark transition-colors"
      >
        View update
        <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </article>
</li>
