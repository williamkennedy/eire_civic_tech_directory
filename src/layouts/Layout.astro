---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogType?: string;
  schema?: object;
}

const {
  title = 'Citizen Data',
  description = 'A curated directory of Irish civic tech projects — tools, platforms, and initiatives that empower citizens and strengthen democratic participation across Ireland.',
  canonical,
  ogType = 'website',
  schema,
} = Astro.props;

const fullTitle = title === 'Citizen Data' ? title : `${title} — Citizen Data`;
const canonicalURL = new URL(canonical || Astro.url.pathname, Astro.site);

const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Citizen Data",
  "url": "https://citizendata.ie",
  "description": description,
  "author": {
    "@type": "Person",
    "name": "William Kennedy",
    "url": "https://williamkennedy.ninja"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Helmet Head",
    "url": "https://helmethead.ie"
  }
};

const pageSchema = schema || defaultSchema;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="Citizen Data" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="bg-irish-green text-white shadow-lg">
      <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center shadow-md group-hover:shadow-lg transition-shadow">
            <span class="text-irish-green font-extrabold text-lg">É</span>
          </div>
          <span class="font-bold text-xl tracking-tight">Citizen Data</span>
        </a>
        <nav class="flex items-center gap-1">
          <a
            href="/"
            class="px-4 py-2 rounded-lg font-medium text-white/90 hover:text-white hover:bg-white/10 transition-colors"
          >
            Home
          </a>
          <a
            href="/about"
            class="px-4 py-2 rounded-lg font-medium text-white/90 hover:text-white hover:bg-white/10 transition-colors"
          >
            About
          </a>
<a
            href="https://github.com/williamkennedy/eire_civic_tech_directory"
            class="px-4 py-2 rounded-lg font-medium text-white/90 hover:text-white hover:bg-white/10 transition-colors"
          >
            Submit
          </a>

        </nav>
      </div>
    </header>
    <slot />
    <footer class="bg-irish-charcoal text-white/70 py-8 mt-16">
      <div class="max-w-6xl mx-auto px-6 text-center text-sm space-y-2">
        <p>Citizen Data — Showcasing Irish civic technology</p>
        <p>
          Built by
          <a
            href="https://williamkennedy.ninja"
            target="_blank"
            rel="noopener noreferrer author me"
            title="William Kennedy — Software engineer and civic tech advocate"
            class="text-white/90 hover:text-white underline underline-offset-2 transition-colors"
          >
            William Kennedy
          </a>
          of
          <a
            href="https://helmethead.ie"
            target="_blank"
            rel="noopener noreferrer"
            title="Helmet Head — Irish software consultancy"
            class="text-white/90 hover:text-white underline underline-offset-2 transition-colors"
          >
            Helmet Head
          </a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }
</style>
