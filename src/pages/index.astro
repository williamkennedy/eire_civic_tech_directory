---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const categories = [...new Set(projects.map((p) => p.data.category))].sort();
const owners = [...new Set(projects.map((p) => p.data.owner))].sort();

const activeBadge = 'bg-irish-green/10 text-irish-green border-irish-green/20';
const inactiveBadge = 'bg-gray-100 text-gray-600 border-gray-200';

const selectClass =
  'w-full sm:w-auto appearance-none bg-white border border-irish-stone rounded-lg px-4 py-2.5 pr-10 text-sm font-medium text-irish-charcoal shadow-sm hover:border-irish-green/40 focus:outline-none focus:ring-2 focus:ring-irish-green/30 focus:border-irish-green transition-colors';
---

<Layout>
  <main class="max-w-6xl mx-auto px-6 py-12">
    {/* Hero Card */}
    <section class="mb-12">
      <div class="bg-white rounded-2xl shadow-md border border-irish-stone p-8 md:p-12 text-center relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-irish-green via-white to-irish-orange"></div>
        <div class="relative z-10">
          <h1 class="text-4xl md:text-5xl font-extrabold text-irish-charcoal mb-4 tracking-tight">
            Éire 2.0 Directory
          </h1>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">
            A curated directory of Irish civic tech projects — tools, platforms, and initiatives 
            that empower citizens and strengthen democratic participation across Ireland.
          </p>
        </div>
      </div>
    </section>

    {/* Stats Bar */}
    <section class="mb-12">
      <div class="bg-irish-green rounded-2xl shadow-md p-6 md:p-8 text-white">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
          <div class="p-4">
            <p class="text-3xl font-bold">{projects.length}</p>
            <p class="text-white/80 text-sm font-medium mt-1">Projects Listed</p>
          </div>
          <div class="p-4 border-t md:border-t-0 md:border-l border-white/20">
            <p class="text-3xl font-bold">{new Set(projects.map(p => p.data.category)).size}</p>
            <p class="text-white/80 text-sm font-medium mt-1">Categories</p>
          </div>
          <div class="p-4 border-t md:border-t-0 md:border-l border-white/20">
            <p class="text-3xl font-bold">{projects.filter(p => p.data.status).length}</p>
            <p class="text-white/80 text-sm font-medium mt-1">Active Projects</p>
          </div>
        </div>
      </div>
    </section>

    {/* Projects Grid */}
    <section>
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-8">
        <h2 class="text-2xl font-bold text-irish-charcoal">Projects</h2>
        <div class="flex flex-col sm:flex-row gap-3">
          <div class="relative">
            <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
            </svg>
            <input
              id="filter-search"
              type="search"
              placeholder="Search projects…"
              aria-label="Search projects"
              class="w-full sm:w-64 bg-white border border-irish-stone rounded-lg pl-10 pr-4 py-2.5 text-sm font-medium text-irish-charcoal shadow-sm placeholder:text-gray-400 hover:border-irish-green/40 focus:outline-none focus:ring-2 focus:ring-irish-green/30 focus:border-irish-green transition-colors"
            />
          </div>
          <div class="relative">
            <select id="filter-category" aria-label="Filter by category" class={selectClass}>
              <option value="">All categories</option>
              {categories.map((category) => (
                <option value={category}>{category}</option>
              ))}
            </select>
            <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
          <div class="relative">
            <select id="filter-owner" aria-label="Filter by owner" class={selectClass}>
              <option value="">All owners</option>
              {owners.map((owner) => (
                <option value={owner}>{owner}</option>
              ))}
            </select>
            <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
          <label class="inline-flex items-center gap-2 px-4 py-2.5 bg-white border border-irish-stone rounded-lg shadow-sm text-sm font-medium text-irish-charcoal cursor-pointer hover:border-irish-green/40 transition-colors select-none">
            <input id="filter-opensource" type="checkbox" class="accent-irish-green w-4 h-4" />
            Open source
          </label>
        </div>
      </div>

      <div class="flex items-center justify-end mb-6">
        <span id="project-count" class="text-sm text-gray-500 font-medium">{projects.length} total</span>
      </div>

      <ul id="project-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <li
            data-category={project.data.category}
            data-owner={project.data.owner}
            data-opensource={project.data.repo ? 'true' : 'false'}
            data-search={`${project.data.title} ${project.data.description} ${project.data.category} ${project.data.owner}`.toLowerCase()}
          >
            <article class="bg-white rounded-xl shadow-sm border border-irish-stone hover:shadow-lg hover:border-irish-green/30 transition-all duration-300 h-full flex flex-col group">
              <div class="p-6 flex-1 flex flex-col">
                <div class="flex items-start justify-between mb-4">
                  <a href={`/project/${project.id}`} class="group/title">
                    <h3 class="text-lg font-bold text-irish-charcoal group-hover/title:text-irish-green transition-colors leading-tight">
                      {project.data.title}
                    </h3>
                  </a>
                  <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold border ml-2 shrink-0 ${project.data.status ? activeBadge : inactiveBadge}`}>
                    {project.data.status ? 'Active' : 'Inactive'}
                  </span>
                </div>

                <a href={`/project/${project.id}`} class="group/desc block flex-1">
                  <p class="text-sm text-gray-600 mb-4 leading-relaxed group-hover/desc:text-gray-800 transition-colors">
                    {project.data.description}
                  </p>
                </a>

                <div class="space-y-2 mb-5">
                  <div class="flex items-center text-sm">
                    <span class="text-gray-400 font-medium w-20 shrink-0">Category</span>
                    <span class="text-irish-charcoal font-medium">{project.data.category}</span>
                  </div>
                  <div class="flex items-center text-sm">
                    <span class="text-gray-400 font-medium w-20 shrink-0">Owner</span>
                    <span class="text-irish-charcoal">{project.data.owner}</span>
                  </div>
                </div>

                {project.data.repo && (
                  <a
                    href={project.data.repo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 self-start mb-5 px-2.5 py-1 rounded-full text-xs font-semibold bg-irish-charcoal/5 text-irish-charcoal border border-irish-stone hover:bg-irish-charcoal hover:text-white transition-colors"
                  >
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
                    </svg>
                    Open Source
                  </a>
                )}

                <div class="flex gap-2 mt-auto">
                  <a
                    href={`/project/${project.id}`}
                    class="flex-1 inline-flex items-center justify-center px-4 py-2.5 bg-irish-cream text-irish-charcoal text-sm font-semibold rounded-lg hover:bg-irish-stone transition-colors border border-irish-stone"
                  >
                    Learn More
                  </a>
                  <a
                    href={project.data.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-1 inline-flex items-center justify-center px-4 py-2.5 bg-irish-green text-white text-sm font-semibold rounded-lg hover:bg-irish-green-dark transition-colors shadow-sm hover:shadow"
                  >
                    Visit Site
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          </li>
        ))}
      </ul>

      <p id="no-results" class="hidden text-center text-gray-500 py-16">
        No projects match these filters.
      </p>
    </section>
  </main>
</Layout>

<script>
  const searchInput = document.getElementById('filter-search') as HTMLInputElement | null;
  const categorySelect = document.getElementById('filter-category') as HTMLSelectElement | null;
  const ownerSelect = document.getElementById('filter-owner') as HTMLSelectElement | null;
  const openSourceToggle = document.getElementById('filter-opensource') as HTMLInputElement | null;
  const grid = document.getElementById('project-grid');
  const count = document.getElementById('project-count');
  const noResults = document.getElementById('no-results');

  if (searchInput && categorySelect && ownerSelect && openSourceToggle && grid && count && noResults) {
    const items = Array.from(grid.querySelectorAll<HTMLLIElement>('li'));

    const applyFilters = () => {
      const query = searchInput.value.trim().toLowerCase();
      const category = categorySelect.value;
      const owner = ownerSelect.value;
      const openSourceOnly = openSourceToggle.checked;
      let visible = 0;

      for (const item of items) {
        const matches =
          (!query || (item.dataset.search ?? '').includes(query)) &&
          (!category || item.dataset.category === category) &&
          (!owner || item.dataset.owner === owner) &&
          (!openSourceOnly || item.dataset.opensource === 'true');
        item.classList.toggle('hidden', !matches);
        if (matches) visible++;
      }

      count.textContent = `${visible} ${visible === 1 ? 'project' : 'projects'}`;
      noResults.classList.toggle('hidden', visible > 0);
    };

    searchInput.addEventListener('input', applyFilters);
    categorySelect.addEventListener('change', applyFilters);
    ownerSelect.addEventListener('change', applyFilters);
    openSourceToggle.addEventListener('change', applyFilters);
  }
</script>
