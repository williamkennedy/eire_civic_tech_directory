---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const activeBadge = 'bg-irish-green/10 text-irish-green border-irish-green/20';
const inactiveBadge = 'bg-gray-100 text-gray-600 border-gray-200';
---

<Layout>
  <main class="max-w-6xl mx-auto px-6 py-12">
    {/* Hero Card */}
    <section class="mb-12">
      <div class="bg-white rounded-2xl shadow-md border border-irish-stone p-8 md:p-12 text-center relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-irish-green via-white to-irish-orange"></div>
        <div class="relative z-10">
          <h1 class="text-4xl md:text-5xl font-extrabold text-irish-charcoal mb-4 tracking-tight">
            Éire 2.0
          </h1>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">
            A curated directory of Irish civic tech projects — tools, platforms, and initiatives 
            that empower citizens and strengthen democratic participation across Ireland.
          </p>
        </div>
      </div>
    </section>

    {/* Stats Bar */}
    <section class="mb-12">
      <div class="bg-irish-green rounded-2xl shadow-md p-6 md:p-8 text-white">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
          <div class="p-4">
            <p class="text-3xl font-bold">{projects.length}</p>
            <p class="text-white/80 text-sm font-medium mt-1">Projects Listed</p>
          </div>
          <div class="p-4 border-t md:border-t-0 md:border-l border-white/20">
            <p class="text-3xl font-bold">{new Set(projects.map(p => p.data.category)).size}</p>
            <p class="text-white/80 text-sm font-medium mt-1">Categories</p>
          </div>
          <div class="p-4 border-t md:border-t-0 md:border-l border-white/20">
            <p class="text-3xl font-bold">{projects.filter(p => p.data.status).length}</p>
            <p class="text-white/80 text-sm font-medium mt-1">Active Projects</p>
          </div>
        </div>
      </div>
    </section>

    {/* Projects Grid */}
    <section>
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-irish-charcoal">Projects</h2>
        <span class="text-sm text-gray-500 font-medium">{projects.length} total</span>
      </div>

      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <li>
            <article class="bg-white rounded-xl shadow-sm border border-irish-stone hover:shadow-lg hover:border-irish-green/30 transition-all duration-300 h-full flex flex-col group">
              <div class="p-6 flex-1 flex flex-col">
                <div class="flex items-start justify-between mb-4">
                  <h3 class="text-lg font-bold text-irish-charcoal group-hover:text-irish-green transition-colors leading-tight">
                    {project.data.title}
                  </h3>
                  <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold border ml-2 shrink-0 ${project.data.status ? activeBadge : inactiveBadge}`}>
                    {project.data.status ? 'Active' : 'Inactive'}
                  </span>
                </div>

                <p class="text-sm text-gray-600 mb-4 leading-relaxed flex-1">
                  {project.data.description}
                </p>

                <div class="space-y-2 mb-5">
                  <div class="flex items-center text-sm">
                    <span class="text-gray-400 font-medium w-20 shrink-0">Category</span>
                    <span class="text-irish-charcoal font-medium">{project.data.category}</span>
                  </div>
                  <div class="flex items-center text-sm">
                    <span class="text-gray-400 font-medium w-20 shrink-0">Owner</span>
                    <span class="text-irish-charcoal">{project.data.owner}</span>
                  </div>
                </div>

                <a
                  href={project.data.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center w-full px-4 py-2.5 bg-irish-green text-white text-sm font-semibold rounded-lg hover:bg-irish-green-dark transition-colors shadow-sm hover:shadow"
                >
                  Visit Project
                  <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
            </article>
          </li>
        ))}
      </ul>
    </section>
  </main>
</Layout>
