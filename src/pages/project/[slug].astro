---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const pageTitle = project.data.title;
const pageDescription = project.data.description;
const projectUrl = project.data.link;

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": project.data.title,
  "description": project.data.description,
  "url": projectUrl,
  "applicationCategory": project.data.category,
  "author": {
    "@type": "Person",
    "name": "William Kennedy",
    "url": "https://williamkennedy.ninja"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Helmet Head",
    "url": "https://helmethead.ie"
  },
  "isPartOf": {
    "@type": "WebSite",
    "name": "Citizen Data",
    "url": "https://citizendata.ie"
  }
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schema={schema}
>
  <main class="max-w-4xl mx-auto px-6 py-12">
    {/* Breadcrumb */}
    <nav class="mb-8" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li>
          <a href="/" class="hover:text-irish-green transition-colors">Home</a>
        </li>
        <li aria-hidden="true">/</li>
        <li class="text-irish-charcoal font-medium" aria-current="page">{project.data.title}</li>
      </ol>
    </nav>

    {/* Project Card */}
    <article class="bg-white rounded-2xl shadow-md border border-irish-stone overflow-hidden">
      {/* Tricolor accent bar */}
      <div class="h-2 bg-gradient-to-r from-irish-green via-white to-irish-orange"></div>

      <div class="p-8 md:p-12">
        <div class="flex items-start justify-between mb-6">
          <h1 class="text-3xl md:text-4xl font-extrabold text-irish-charcoal tracking-tight">
            {project.data.title}
          </h1>
          <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border shrink-0 ml-4 ${project.data.status ? 'bg-irish-green/10 text-irish-green border-irish-green/20' : 'bg-gray-100 text-gray-600 border-gray-200'}`}>
            {project.data.status ? 'Active' : 'Inactive'}
          </span>
        </div>

        <p class="text-lg text-gray-600 leading-relaxed mb-8">
          {project.data.description}
        </p>

        {project.data.repo && (
          <a
            href={project.data.repo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mb-8 px-4 py-2 rounded-full text-sm font-semibold bg-irish-charcoal/5 text-irish-charcoal border border-irish-stone hover:bg-irish-charcoal hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
            </svg>
            Open Source — View on GitHub
          </a>
        )}

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10 p-6 bg-irish-cream rounded-xl border border-irish-stone">
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Category</p>
            <p class="text-irish-charcoal font-medium">{project.data.category}</p>
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Owner</p>
            <p class="text-irish-charcoal font-medium">{project.data.owner}</p>
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Status</p>
            <p class="text-irish-charcoal font-medium">{project.data.status ? 'Active' : 'Inactive'}</p>
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Website</p>
            <a
              href={projectUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-irish-green hover:text-irish-green-dark font-medium underline underline-offset-2 transition-colors"
            >
              {new URL(projectUrl).hostname}
            </a>
          </div>
        </div>

        {Content && (
          <div class="prose prose-slate max-w-none mb-10">
            <Content />
          </div>
        )}

        <a
          href={projectUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-3.5 bg-irish-green text-white font-bold rounded-xl hover:bg-irish-green-dark transition-colors shadow-md hover:shadow-lg"
        >
          Visit Project
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </article>

    {/* Related / Back to projects */}
    <div class="mt-10 text-center">
      <a
        href="/"
        class="inline-flex items-center text-sm text-gray-500 hover:text-irish-green transition-colors"
      >
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to all projects
      </a>
    </div>
  </main>
</Layout>
